rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function signedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return signedIn() && request.auth.uid == userId;
    }

    function validAccountType(value) {
      return value in ['talent', 'business', 'agency', 'admin', 'owner'];
    }

    function validPublicAccountType(value) {
      return value in ['talent', 'business', 'agency'];
    }

    function isPrivilegedAccount() {
      return signedIn() &&
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.accountType in ['admin', 'owner'];
    }

    function hasBlogRole() {
      return signedIn() && (
        isPrivilegedAccount() ||
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.blogRole in ['writer', 'publisher']
      );
    }

    function accountTypeIsCreateValid() {
      return !('accountType' in request.resource.data) ||
        request.resource.data.accountType == null ||
        validAccountType(request.resource.data.accountType);
    }

    function accountTypeIsImmutable() {
      return !('accountType' in resource.data) ||
        resource.data.accountType == null ||
        request.resource.data.accountType == resource.data.accountType;
    }

    function lockMetadataIsImmutable() {
      return !('accountTypeLocked' in resource.data) ||
        resource.data.accountTypeLocked != true ||
        (
          request.resource.data.accountTypeLocked == resource.data.accountTypeLocked &&
          request.resource.data.accountTypeLockedAt == resource.data.accountTypeLockedAt &&
          request.resource.data.accountTypeSource == resource.data.accountTypeSource
        );
    }

    function roleMatchesAccountType() {
      return !('accountType' in request.resource.data) ||
        request.resource.data.accountType == null ||
        request.resource.data.role == request.resource.data.accountType;
    }

    function billingFieldsAreServerOwnedOnCreate() {
      return !('billing' in request.resource.data) &&
        !('entitlements' in request.resource.data) &&
        !('blogRole' in request.resource.data);
    }

    function serverOwnedFieldsAreImmutable() {
      return !request.resource.data.diff(resource.data).affectedKeys().hasAny([
        'billing',
        'entitlements',
        'accountType',
        'role',
        'accountTypeLocked',
        'accountTypeLockedAt',
        'accountTypeSource',
        'moderationStatus',
        'disabled',
        'lastAdminActionAt',
        'lastAdminActionBy',
        'adminNotes',
        'blogRole'
      ]);
    }

    // Job listings - require authentication
    match /jobs/{jobId} {
      allow read: if request.auth != null;
      allow write: if request.auth != null;
    }

    // Scraped jobs - require authentication
    match /scrapedJobs/{jobId} {
      allow read: if request.auth != null;
      allow write: if request.auth != null;
    }

    // Company profiles - require authentication
    match /companies/{companyId} {
      allow read: if request.auth != null;
      allow write: if request.auth != null;
    }

    // Private account profiles - owner can read/write, admin/owner can read for operations.
    match /users/{userId} {
      allow read: if isOwner(userId) || isPrivilegedAccount();
      allow create: if isOwner(userId) &&
        accountTypeIsCreateValid() &&
        billingFieldsAreServerOwnedOnCreate();
      allow update: if isOwner(userId) &&
        accountTypeIsImmutable() &&
        lockMetadataIsImmutable() &&
        roleMatchesAccountType() &&
        serverOwnedFieldsAreImmutable();
      allow delete: if isOwner(userId);
    }

    // Stripe webhook idempotency records are written only through the Admin SDK.
    match /stripeEvents/{eventId} {
      allow read, write: if false;
    }

    // Platform configuration, including live pricing, is server-owned and
    // exposed only through validated API routes.
    match /platformConfig/{configId} {
      allow read, write: if false;
    }

    // Published public profile projections. These contain only opted-in fields.
    match /publicProfiles/{userId} {
      allow read: if resource.data.status == 'published' &&
        resource.data.moderationStatus == 'active';
      allow create, update: if isOwner(userId) &&
        validPublicAccountType(request.resource.data.accountType) &&
        request.resource.data.uid == userId &&
        request.resource.data.status in ['draft', 'published', 'hidden', 'suspended'];
      allow delete: if isOwner(userId);
    }

    // Agency roster approvals. Agencies can invite; talent controls approval for their own listing.
    match /agencyRosterInvites/{inviteId} {
      allow read: if signedIn() && (
        request.auth.uid == resource.data.agencyUid ||
        request.auth.uid == resource.data.talentUid ||
        isPrivilegedAccount()
      );
      allow create: if signedIn() &&
        request.resource.data.agencyUid == request.auth.uid &&
        request.resource.data.status == 'pending';
      allow update: if signedIn() && (
        request.auth.uid == resource.data.talentUid ||
        request.auth.uid == resource.data.agencyUid
      );
      allow delete: if signedIn() && (
        request.auth.uid == resource.data.agencyUid ||
        isPrivilegedAccount()
      );
    }

    // Private operator preview profiles for admin/owner layout testing.
    match /operatorPreviewProfiles/{operatorId}/paths/{accountType} {
      allow read: if isOwner(operatorId) &&
        isPrivilegedAccount() &&
        validPublicAccountType(accountType);
      allow create, update: if isOwner(operatorId) &&
        isPrivilegedAccount() &&
        validPublicAccountType(accountType) &&
        (!('accountType' in request.resource.data) || request.resource.data.accountType == accountType) &&
        (!('role' in request.resource.data) || request.resource.data.role == accountType);
      allow delete: if isOwner(operatorId) &&
        isPrivilegedAccount() &&
        validPublicAccountType(accountType);
    }

    // Connections - participants only
    match /connections/{connectionId} {
      allow read: if request.auth != null && (
        resource.data.requesterId == request.auth.uid ||
        resource.data.targetId == request.auth.uid
      );
      allow create: if request.auth != null &&
        request.resource.data.requesterId == request.auth.uid &&
        request.resource.data.targetId is string &&
        request.resource.data.targetId != request.auth.uid &&
        request.resource.data.status in ['pending', 'accepted'];
      allow update: if request.auth != null && (
        resource.data.requesterId == request.auth.uid ||
        resource.data.targetId == request.auth.uid
      );
      allow delete: if request.auth != null && (
        resource.data.requesterId == request.auth.uid ||
        resource.data.targetId == request.auth.uid
      );
    }

    // Interview settings - only owner can read/write
    match /auditionSettings/{userId} {
      allow read: if request.auth != null && request.auth.uid == userId;
      allow write: if request.auth != null && request.auth.uid == userId;
    }

    // Interview session history - only owner can read/write
    match /auditionSessions/{userId}/sessions/{sessionId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }

    // Interview metering reservations are server-owned.
    match /auditionMetering/{meterId} {
      allow read, create, update, delete: if false;
    }

    // Business screening links are created through server routes. Candidates use token APIs.
    match /businessScreeningLinks/{linkId} {
      allow read: if signedIn() && resource.data.businessUid == request.auth.uid;
      allow create, update, delete: if false;
    }

    // Business screening reports are private to the owning Business account.
    match /businessScreeningReports/{reportId} {
      allow read: if signedIn() && resource.data.businessUid == request.auth.uid;
      allow create, update, delete: if false;
    }

    // Recorded business screening media metadata is server-owned. Review access
    // goes through API routes so playback URLs and delete events can be audited.
    match /businessScreeningRecordingConsents/{consentId} {
      allow read: if signedIn() && (
        resource.data.businessUid == request.auth.uid ||
        isPrivilegedAccount()
      );
      allow create, update, delete: if false;
    }

    match /businessScreeningRecordings/{recordingId} {
      allow read: if signedIn() && (
        resource.data.businessUid == request.auth.uid ||
        isPrivilegedAccount()
      );
      allow create, update, delete: if false;
    }

    match /businessScreeningRecordingEvents/{eventId} {
      allow read: if isPrivilegedAccount();
      allow create, update, delete: if false;
    }

    // Premium currency wallets - server-owned balances and ledger.
    match /accountWallets/{userId} {
      allow read: if isOwner(userId);
      allow create, update, delete: if false;

      match /transactions/{transactionId} {
        allow read: if isOwner(userId);
        allow create, update, delete: if false;
      }
    }

    // Immutable admin operation audit trail. Server routes write these through Admin SDK.
    match /adminAuditLogs/{logId} {
      allow read: if isPrivilegedAccount();
      allow create, update, delete: if false;
    }

    // Blog posts - published posts are public; drafts are visible to blog workers.
    // Writes go through server API routes so author, review, and publishing
    // metadata can be validated consistently.
    match /blogPosts/{postId} {
      allow read: if resource.data.status == 'published' || hasBlogRole();
      allow create, update, delete: if false;
    }

    // Conversations (Messaging)
    match /conversations/{conversationId} {
      // Participants can read conversation metadata. All mutations go through
      // authenticated server routes so messages, receipts, AI metadata, and
      // audit events are validated and tracked consistently.
      allow read: if request.auth != null && request.auth.uid in resource.data.participantIds;
      allow create, update, delete: if false;

      // Messages subcollection
      match /messages/{messageId} {
        allow read: if request.auth != null && request.auth.uid in get(/databases/$(database)/documents/conversations/$(conversationId)).data.participantIds;
        allow create, update, delete: if false;
      }

      // Immutable chat event trail written by server routes.
      match /events/{eventId} {
        allow read, create, update, delete: if false;
      }
    }
  }
}
