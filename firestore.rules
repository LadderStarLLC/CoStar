rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function signedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return signedIn() && request.auth.uid == userId;
    }

    function validAccountType(value) {
      return value in ['talent', 'business', 'agency', 'admin', 'owner'];
    }

    function validPublicAccountType(value) {
      return value in ['talent', 'business', 'agency'];
    }

    function isPrivilegedAccount() {
      return signedIn() &&
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.accountType in ['admin', 'owner'];
    }

    function accountTypeIsCreateValid() {
      return !('accountType' in request.resource.data) ||
        request.resource.data.accountType == null ||
        validAccountType(request.resource.data.accountType);
    }

    function accountTypeIsImmutable() {
      return !('accountType' in resource.data) ||
        resource.data.accountType == null ||
        request.resource.data.accountType == resource.data.accountType;
    }

    function lockMetadataIsImmutable() {
      return !('accountTypeLocked' in resource.data) ||
        resource.data.accountTypeLocked != true ||
        (
          request.resource.data.accountTypeLocked == resource.data.accountTypeLocked &&
          request.resource.data.accountTypeLockedAt == resource.data.accountTypeLockedAt &&
          request.resource.data.accountTypeSource == resource.data.accountTypeSource
        );
    }

    function roleMatchesAccountType() {
      return !('accountType' in request.resource.data) ||
        request.resource.data.accountType == null ||
        request.resource.data.role == request.resource.data.accountType;
    }

    function billingFieldsAreServerOwnedOnCreate() {
      return !('billing' in request.resource.data) &&
        !('entitlements' in request.resource.data);
    }

    function serverOwnedFieldsAreImmutable() {
      return !request.resource.data.diff(resource.data).affectedKeys().hasAny([
        'billing',
        'entitlements',
        'accountType',
        'role',
        'accountTypeLocked',
        'accountTypeLockedAt',
        'accountTypeSource',
        'moderationStatus',
        'disabled',
        'lastAdminActionAt',
        'lastAdminActionBy',
        'adminNotes'
      ]);
    }

    // Job listings - require authentication
    match /jobs/{jobId} {
      allow read: if request.auth != null;
      allow write: if request.auth != null;
    }

    // Scraped jobs - require authentication
    match /scrapedJobs/{jobId} {
      allow read: if request.auth != null;
      allow write: if request.auth != null;
    }

    // Company profiles - require authentication
    match /companies/{companyId} {
      allow read: if request.auth != null;
      allow write: if request.auth != null;
    }

    // Private account profiles - owner can read/write, admin/owner can read for operations.
    match /users/{userId} {
      allow read: if isOwner(userId) || isPrivilegedAccount();
      allow create: if isOwner(userId) &&
        accountTypeIsCreateValid() &&
        billingFieldsAreServerOwnedOnCreate();
      allow update: if isOwner(userId) &&
        accountTypeIsImmutable() &&
        lockMetadataIsImmutable() &&
        roleMatchesAccountType() &&
        serverOwnedFieldsAreImmutable();
      allow delete: if isOwner(userId);
    }

    // Stripe webhook idempotency records are written only through the Admin SDK.
    match /stripeEvents/{eventId} {
      allow read, write: if false;
    }

    // Published public profile projections. These contain only opted-in fields.
    match /publicProfiles/{userId} {
      allow read: if resource.data.status == 'published' &&
        resource.data.moderationStatus == 'active';
      allow create, update: if isOwner(userId) &&
        validPublicAccountType(request.resource.data.accountType) &&
        request.resource.data.uid == userId &&
        request.resource.data.status in ['draft', 'published', 'hidden', 'suspended'];
      allow delete: if isOwner(userId);
    }

    // Agency roster approvals. Agencies can invite; talent controls approval for their own listing.
    match /agencyRosterInvites/{inviteId} {
      allow read: if signedIn() && (
        request.auth.uid == resource.data.agencyUid ||
        request.auth.uid == resource.data.talentUid ||
        isPrivilegedAccount()
      );
      allow create: if signedIn() &&
        request.resource.data.agencyUid == request.auth.uid &&
        request.resource.data.status == 'pending';
      allow update: if signedIn() && (
        request.auth.uid == resource.data.talentUid ||
        request.auth.uid == resource.data.agencyUid
      );
      allow delete: if signedIn() && (
        request.auth.uid == resource.data.agencyUid ||
        isPrivilegedAccount()
      );
    }

    // Private operator preview profiles for admin/owner layout testing.
    match /operatorPreviewProfiles/{operatorId}/paths/{accountType} {
      allow read: if isOwner(operatorId) &&
        isPrivilegedAccount() &&
        validPublicAccountType(accountType);
      allow create, update: if isOwner(operatorId) &&
        isPrivilegedAccount() &&
        validPublicAccountType(accountType) &&
        (!('accountType' in request.resource.data) || request.resource.data.accountType == accountType) &&
        (!('role' in request.resource.data) || request.resource.data.role == accountType);
      allow delete: if isOwner(operatorId) &&
        isPrivilegedAccount() &&
        validPublicAccountType(accountType);
    }

    // Connections - participants only
    match /connections/{connectionId} {
      allow read: if request.auth != null && (
        resource.data.uid1 == request.auth.uid ||
        resource.data.uid2 == request.auth.uid
      );
      allow create: if request.auth != null &&
        request.resource.data.initiatedBy == request.auth.uid && (
          request.resource.data.uid1 == request.auth.uid ||
          request.resource.data.uid2 == request.auth.uid
        );
      allow update: if request.auth != null && (
        resource.data.uid1 == request.auth.uid ||
        resource.data.uid2 == request.auth.uid
      );
      allow delete: if request.auth != null && (
        resource.data.uid1 == request.auth.uid ||
        resource.data.uid2 == request.auth.uid
      );
    }

    // Audition settings - only owner can read/write
    match /auditionSettings/{userId} {
      allow read: if request.auth != null && request.auth.uid == userId;
      allow write: if request.auth != null && request.auth.uid == userId;
    }

    // Audition session history - only owner can read/write
    match /auditionSessions/{userId}/sessions/{sessionId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }

    // Premium currency wallets - server-owned balances and ledger.
    match /accountWallets/{userId} {
      allow read: if isOwner(userId);
      allow create, update, delete: if false;

      match /transactions/{transactionId} {
        allow read: if isOwner(userId);
        allow create, update, delete: if false;
      }
    }

    // Immutable admin operation audit trail. Server routes write these through Admin SDK.
    match /adminAuditLogs/{logId} {
      allow read: if isPrivilegedAccount();
      allow create, update, delete: if false;
    }

    // Blog posts - published posts are public; drafts and writes are admin/owner only.
    match /blogPosts/{postId} {
      allow read: if resource.data.status == 'published' || isPrivilegedAccount();
      allow create, update, delete: if isPrivilegedAccount();
    }

    // Conversations (Messaging)
    match /conversations/{conversationId} {
      // Only participants can read the conversation metadata
      allow read: if request.auth != null && request.auth.uid in resource.data.participantIds;
      
      // Only participants can start/update a conversation
      allow create: if request.auth != null && request.auth.uid in request.resource.data.participantIds;
      allow update: if request.auth != null && request.auth.uid in resource.data.participantIds;

      // Messages subcollection
      match /messages/{messageId} {
        // Must check parent conversation to ensure user is a participant
        allow read: if request.auth != null && request.auth.uid in get(/databases/$(database)/documents/conversations/$(conversationId)).data.participantIds;
        allow create: if request.auth != null && request.auth.uid in get(/databases/$(database)/documents/conversations/$(conversationId)).data.participantIds;
      }
    }
  }
}
